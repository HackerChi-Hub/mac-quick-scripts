#!/usr/bin/env bash
# game-res — MacBook 游戏模式一键切换 (game-on / game-off 共用主体)
#   game-on  : 避刘海分辨率 1512x945 + 关闭热区 (防游戏误触)  [整合 hc-off]
#   game-off : 默认分辨率 1512x982 + 恢复热区                  [整合 hc-on]
#   无参数    : 显示当前状态 (分辨率 + 热区) 和用法
# 依赖: displayplacer  (brew install displayplacer)
# 用法: 直接调 game-on / game-off (符号链接), 或 game-res on / game-res off
set -uo pipefail
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

# ── 配置 (如需调整改这里) ──
GAME_RES="1512x945"        # 避刘海分辨率 (比默认矮 37px = 刘海高度)
DEFAULT_RES="1512x982"     # 默认 Retina 分辨率
HZ="120"
COLOR_DEPTH="8"

# ── 颜色 ──
G=$'\033[0;32m'; Y=$'\033[1;33m'; R=$'\033[0;31m'; B=$'\033[1m'; N=$'\033[0m'

# ── 依赖检查 ──
command -v displayplacer >/dev/null 2>&1 || {
  printf "${R}✗ 未安装 displayplacer${N}\n" >&2
  printf "  请运行: ${B}brew install displayplacer${N}\n" >&2
  exit 1
}

# ── 自动获取内置屏 ID (不硬编码,换机也能用) ──
SCREEN_ID=$(displayplacer list 2>/dev/null | awk '
  /Persistent screen id:/ { last=$NF }
  /Type: MacBook built in screen/ { print last; exit }
')

[ -z "$SCREEN_ID" ] && {
  printf "${R}✗ 未找到 MacBook 内置屏${N}\n" >&2
  printf "  (可能正在使用外接屏,或 displayplacer 输出格式变化)\n" >&2
  exit 1
}

# ── 读取当前分辨率 ──
current_res() {
  displayplacer list 2>/dev/null | awk '
    /Type: MacBook built in screen/ { found=1; next }
    found && /^Resolution:/ { print $2; exit }
  '
}
CUR_RES=$(current_res)

# ── 切换函数 ──
switch_to() {
  local target="$1" label="$2"
  if [ "$CUR_RES" = "$target" ]; then
    printf "${Y}• 当前已是 ${label} (${target})，无需切换${N}\n"
    return 0
  fi
  if displayplacer "id:${SCREEN_ID} res:${target} hz:${HZ} color_depth:${COLOR_DEPTH} scaling:on"; then
    printf "${G}✓ 已切换到 ${label}  ${B}${target}${N}${G} (原 ${CUR_RES})${N}\n"
  else
    printf "${R}✗ 切换失败${N}\n" >&2
    exit 1
  fi
}

# ── 热区控制 (整合 hc-on / hc-off) ──
# 角落动作值: 1=无, 2=调度中心(右上), 4=桌面(右下), 12=通知中心(右上), 14=启动台(右下)
# hc-on (恢复): tl=2 tr=12 bl=4 br=14   hc-off (全关): 全部=1
hotcorners() {
  local mode="$1" tl tr bl br label
  if [ "$mode" = "off" ]; then
    tl=1; tr=1; bl=1; br=1; label="热区已关闭 (游戏防误触)"
  else
    tl=2; tr=12; bl=4; br=14; label="热区已恢复"
  fi
  # 幂等:左上角已是目标值则跳过 (避免重复 killall Dock 闪烁)
  local cur_tl; cur_tl=$(defaults read com.apple.dock wvous-tl-corner 2>/dev/null || echo "?")
  if [ "$cur_tl" = "$tl" ]; then
    printf "${Y}  • 热区已是目标状态，跳过${N}\n"
    return 0
  fi
  defaults write com.apple.dock wvous-tl-corner -int $tl
  defaults write com.apple.dock wvous-tr-corner -int $tr
  defaults write com.apple.dock wvous-bl-corner -int $bl
  defaults write com.apple.dock wvous-br-corner -int $br
  killall Dock 2>/dev/null
  printf "${G}  ✓ ${label}${N}\n"
}

# ── 判断动作: 符号链接名 > 参数 ──
ACTION=$(basename "$0")
[ "$ACTION" = "game-res" ] && [ $# -gt 0 ] && ACTION="game-$1"

case "$ACTION" in
  game-on)
    switch_to "$GAME_RES" "游戏模式 (避刘海)"
    hotcorners off
    ;;
  game-off)
    switch_to "$DEFAULT_RES" "默认模式"
    hotcorners on
    ;;
  *)
    # 热区当前状态
    hc_tl=$(defaults read com.apple.dock wvous-tl-corner 2>/dev/null || echo "?")
    hc_state=$([ "$hc_tl" = "1" ] && echo "${Y}关闭${N}" || echo "${G}开启${N}")
    printf "${B}game-res${N} — MacBook 游戏模式切换\n"
    printf "────────────────────────────────────────\n"
    printf "分辨率: ${B}${CUR_RES}${N}    热区: ${hc_state}\n"
    printf "  ${G}game-on${N}  → ${GAME_RES} + 热区关  (避刘海,游戏用)\n"
    printf "  ${G}game-off${N} → ${DEFAULT_RES} + 热区开  (默认,日常用)\n"
    [ "$CUR_RES" = "$DEFAULT_RES" ] && [ "$hc_tl" != "1" ] && printf "${Y}状态: 日常模式${N}\n"
    [ "$CUR_RES" = "$GAME_RES" ]    && [ "$hc_tl" = "1" ] && printf "${Y}状态: 游戏模式${N}\n"
    ;;
esac
